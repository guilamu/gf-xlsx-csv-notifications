#: gf-xlsx-csv-notifications.php
msgid "More information about Gravity Forms - XLSX to CSV Notifications"
msgstr "Plus d'informations sur Gravity Forms - XLSX to CSV Notifications"

#: gf-xlsx-csv-notifications.php
msgid "Gravity Forms - XLSX to CSV Notifications"
msgstr "Gravity Forms - XLSX to CSV Notifications"

#: gf-xlsx-csv-notifications.php
msgid "View details"
msgstr "Voir les détails"

#: gf-xlsx-csv-notifications.php
msgid "🐛 Report a Bug"
msgstr "🐛 Signaler un bug"

#: gf-xlsx-csv-notifications.php
msgid "🐛 Report a Bug (install Bug Reporter)"
msgstr "🐛 Signaler un bug (installer Bug Reporter)"

#: includes/class-gf-xlsx-csv-addon.php
msgid "XLSX to CSV"
msgstr "XLSX vers CSV"

#: includes/class-gf-xlsx-csv-addon.php
msgid "This form has no file upload field. Add one to configure the XLSX → CSV conversion."
msgstr "Ce formulaire ne contient aucun champ d'envoi de fichier. Ajoutez-en un pour configurer la conversion XLSX → CSV."

#: includes/class-gf-xlsx-csv-addon.php
msgid "Upload field"
msgstr "Champ d'envoi de fichier"

#. translators: 1: field label, 2: field ID.
#: includes/class-gf-xlsx-csv-addon.php
msgid "XLSX to CSV — %1$s (field #%2$d)"
msgstr "XLSX vers CSV — %1$s (champ n° %2$d)"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Attachment"
msgstr "Pièce jointe"

#: includes/class-gf-xlsx-csv-addon.php
msgid "When enabled, only the converted CSV is attached to notifications. When disabled, both the CSV and the original XLSX are attached."
msgstr "Lorsque cette option est activée, seul le CSV converti est joint aux notifications. Sinon, le CSV et le XLSX d'origine sont tous deux joints."

#: includes/class-gf-xlsx-csv-addon.php
msgid "CSV only (drop XLSX)"
msgstr "CSV uniquement (sans le XLSX)"

#: includes/class-gf-xlsx-csv-addon.php
msgid "CSV delimiter"
msgstr "Délimiteur CSV"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Character used to separate the columns in the generated CSV."
msgstr "Caractère utilisé pour séparer les colonnes dans le CSV généré."

#: includes/class-gf-xlsx-csv-addon.php
msgid "Semicolon ( ; )"
msgstr "Point-virgule ( ; )"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Comma ( , )"
msgstr "Virgule ( , )"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Tab"
msgstr "Tabulation"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Pipe ( | )"
msgstr "Barre verticale ( | )"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Converted worksheet"
msgstr "Feuille de calcul convertie"

#: includes/class-gf-xlsx-csv-addon.php
msgid "Number of the worksheet to convert (1 = first sheet). Falls back to the first sheet if the number does not exist."
msgstr "Numéro de la feuille de calcul à convertir (1 = première feuille). Revient à la première feuille si le numéro n'existe pas."

#: includes/class-github-updater.php
msgid "Requires Gravity Forms:"
msgstr "Nécessite Gravity Forms :"

#: includes/class-github-updater.php
msgid "%s or higher"
msgstr "%s ou supérieur"

#: includes/class-github-updater.php
msgid "Unable to rename the update folder. Please retry or update manually."
msgstr "Impossible de renommer le dossier de mise à jour. Veuillez réessayer ou mettre à jour manuellement."
